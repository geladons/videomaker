# Ollama Configuration
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_TIMEOUT=180
OLLAMA_THINK=false

# Ollama Planner Model
OLLAMA_PLANNER_MODEL=llama3.2:3b
OLLAMA_PLANNER_TIMEOUT=120
OLLAMA_PLANNER_THINK=false

# Ollama Helper Model (for voiceover generation)
OLLAMA_HELPER_MODEL=qwen3.5:2b
OLLAMA_HELPER_TIMEOUT=120
OLLAMA_HELPER_THINK=false

# Ollama Vision Model
OLLAMA_VISION_MODEL=qwen3-vl:2b
OLLAMA_VISION_TIMEOUT=120
OLLAMA_VISION_ENABLED=false

# TTS Configuration
TTS_ENGINE=coqui
COQUI_TTS_MODEL=tts_models/en/vctk/vits
COQUI_TTS_SPEAKER=

# Scraper Configuration
SCRAPER_REQUEST_DELAY=1.2
SCRAPER_YTDLP_SLEEP_MIN=1.0
SCRAPER_YTDLP_SLEEP_MAX=3.0
SCRAPER_YTDLP_SEARCH_COUNT=8
SCRAPER_IMAGE_DELAY=0.6

# Voiceover Configuration
VOICEOVER_WORDS_PER_SEC=2.2

# Models Directory
MODELS_DIR=/models
